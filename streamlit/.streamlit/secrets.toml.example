# Example secrets file for the live (non-demo) build of this dashboard.
# Copy to `secrets.toml` (gitignored) and fill in values to run locally
# against a real BigQuery project.
#
# The public Streamlit Cloud demo does NOT use this file — it sets
# DEMO_MODE=true in the Cloud "Secrets" UI, which short-circuits all of the
# reads below (see streamlit/app.py, streamlit/data/bq_client.py).

# Service-account JSON for BigQuery access. Copy the full JSON contents of
# your downloaded service-account key and inline the fields below.
[gcp_service_account]
type = ""
project_id = ""
private_key_id = ""
private_key = ""
client_email = ""
client_id = ""
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = ""
universe_domain = "googleapis.com"

# Password gate on the dashboard. Required in live mode; ignored in demo mode.
APP_PASSWORD = ""
